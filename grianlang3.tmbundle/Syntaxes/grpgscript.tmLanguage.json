{
  "name": "grianlang3",
  "scopeName": "source.grianlang3",
  "fileTypes": ["gl3"],
  "patterns": [
    {
      "name": "comment.line.double-slash.grianlang3",
      "match": "//.*$"
    },
    {
      "name": "keyword.control.grianlang3",
      "match": "\\b(def|fnc|return|if|else|while|import|struct)\\b"
    },
    {
      "name": "keyword.operator.cast.grianlang3",
      "match": "\\b(as)\\b"
    },
    {
      "name": "keyword.operator.sizeof.grianlang3",
      "match": "\\b(sizeof)\\b"
    },
    {
      "name": "constant.language.boolean.true.grianlang3",
      "match": "\\b(true)\\b"
    },
    {
      "name": "constant.language.boolean.false.grianlang3",
      "match": "\\b(false)\\b"
    },
    {
      "name": "storage.type.grianlang3",
      "match": "\\b(int8|int16|int32|int|uint8|uint16|uint32|uint|char|bool|float|none)\\b\\**"
    },
    {
      "name": "support.function.builtin.grianlang3",
      "match": "\\b(arr_new|arr_free|arr_push|dynstr|str_append|str_len|str_free|dbg_i64|dbg_i32|dbg_i16|dbg_i8|dbg_u64|dbg_u32|dbg_u16|dbg_u8|dbg_float|dbg_bool|dbg_str|dbg_char|__asm__salloc)\\b"
    },
    {
      "name": "string.quoted.double.grianlang3",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.grianlang3",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "string.quoted.single.grianlang3",
      "match": "'[^'\\\\]'"
    },
    {
      "name": "string.quoted.single.escape.grianlang3",
      "match": "'\\\\[^']'"
    },
    {
      "name": "constant.numeric.hex.grianlang3",
      "match": "\\b0x[0-9a-fA-F]+\\b"
    },
    {
      "name": "constant.numeric.float.grianlang3",
      "match": "\\b\\d+\\.\\d+\\b"
    },
    {
      "name": "constant.numeric.integer.grianlang3",
      "match": "\\b\\d+(u64|u32|u16|u8|i32|i16|i8)?\\b"
    },
    {
      "name": "punctuation.separator.arrow.grianlang3",
      "match": "->"
    },
    {
      "name": "keyword.operator.comparison.grianlang3",
      "match": "==|!=|<=|>=|<|>"
    },
    {
      "name": "keyword.operator.logical.grianlang3",
      "match": "&&|\\|\\||!"
    },
    {
      "name": "keyword.operator.assignment.grianlang3",
      "match": "="
    },
    {
      "name": "keyword.operator.arithmetic.grianlang3",
      "match": "[+\\-*/]"
    },
    {
      "name": "keyword.operator.pointer.grianlang3",
      "match": "&"
    },
    {
      "name": "punctuation.definition.block.grianlang3",
      "match": "[{}()]"
    },
    {
      "name": "punctuation.definition.bracket.grianlang3",
      "match": "[\\[\\]]"
    },
    {
      "name": "punctuation.separator.grianlang3",
      "match": "[,;:.]"
    },
    {
      "name": "variable.other.grianlang3",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ]
}
