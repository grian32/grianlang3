import "dbg"

fnc main() -> int32 {
    def int i = 0;
    while true {
        if i >= 6 {
            if i == 6 {
                i = i + 1;
                dbg_str("continue path, incrementing");
                continue;
            }
            dbg_str("break path, exiting");
            break;
        }
        dbg_str("while path, incrementing");
        i = i + 1;
    }

    dbg_str("exiting");


    return 0i32;
}
